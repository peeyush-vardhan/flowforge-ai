{
  "name": "flowforge-ai",
  "private": true,
  "version": "0.1.0",
  "description": "FlowForge AI - an AI workflow builder that converts natural language into executable workflow graphs.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "npm --workspace @flowforge/web run dev",
    "dev:api": "npm --workspace @flowforge/api run dev",
    "build": "npm run build:web && npm run build:api",
    "build:web": "npm --workspace @flowforge/web run build",
    "build:api": "npm --workspace @flowforge/api run build",
    "lint": "npm --workspace @flowforge/web run lint",
    "format": "npm --workspace @flowforge/web run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
